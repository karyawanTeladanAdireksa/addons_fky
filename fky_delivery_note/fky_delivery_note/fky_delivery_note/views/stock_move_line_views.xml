<odoo>
     <data>
 
     <!-- STOCK MOVE LINE - DETAILED OPERATIONS (All Picking Types) -->
     <record id="fky_view_stock_move_line_detailed_operation_tree_inherit_note" model="ir.ui.view">
          <field name="name">fky.stock.move.line.detailed.operation.tree.inherit.note</field>
          <field name="model">stock.move.line</field>
          <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/> 
          <field name="arch" type="xml">
               <xpath expr="//field[@name='product_id']" position="after">  
                    <field name="delivery_note" optional="hide"/>
               </xpath>
          </field>
     </record>

     </data>
</odoo>
